# Server (local dev uses SQLite via server.js; Vercel uses Neon Postgres via DATABASE_URL)
PORT=3000
NODE_ENV=production
DATA_DIR=data
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
ADMIN_TOKEN=change-this-admin-token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
# Only set this when Node is behind a trusted reverse proxy that forwards X-Forwarded-For.
# Common local proxy values: 127.0.0.1,::1
TRUSTED_PROXY_IPS=

# Optional Cloudflare Turnstile spam protection for quote requests.
# Use Cloudflare's test keys locally or real keys in production.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Quote notifications. The backend saves to SQLite even when SMTP is not configured.
QUOTE_NOTIFY_EMAIL=owner@example.com
QUOTE_FROM_EMAIL=website@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TIMEOUT_MS=15000
SMTP_USER=website@example.com
SMTP_PASS=replace-with-smtp-password

# Optional backup settings for scripts/backup-sqlite.js.
BACKUP_DIR=backups
BACKUP_RETENTION=14
AWS_S3_BACKUP_URI=
